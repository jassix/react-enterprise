{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": true,
  "semi": false,
  "singleQuote": true,
  "trailingComma": "all",
  "ignorePatterns": [
    "node_modules",
    "dist",
    "build",
    "*.gen.*",
    "*.min.js",
    "styled-system",
    "gen",
    "luma"
  ]
}
