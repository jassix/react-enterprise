{
  "name": "@lume/primitives",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "lint": "oxlint --type-aware ."
  },
  "dependencies": {
    "@ark-ui/react": "catalog:ui",
    "@iconify/react": "catalog:icons",
    "@lume/foundation": "workspace:"
  },
  "devDependencies": {
    "@repo/oxlint": "workspace:",
    "@size-limit/preset-small-lib": "^11.1.0",
    "@storybook/react-vite": "catalog:storybook",
    "@types/bun": "catalog:",
    "storybook": "catalog:storybook"
  },
  "peerDependencies": {
    "@types/react": "catalog:react",
    "react": "catalog:react",
    "typescript": "catalog:"
  },
  "size-limit": [
    {
      "name": "Button",
      "path": "src/ui/buttons/button/button.tsx",
      "limit": "4 kB",
      "ignore": [
        "@lume/foundation",
        "@lume/foundation/css",
        "@lume/foundation/jsx",
        "@lume/foundation/recipes",
        "@lume/foundation/types",
        "@ark-ui/react",
        "react"
      ]
    },
    {
      "name": "Dialog",
      "path": "src/ui/overlays/dialog/dialog.tsx",
      "limit": "6 kB",
      "ignore": [
        "@lume/foundation",
        "@lume/foundation/css",
        "@lume/foundation/jsx",
        "@lume/foundation/recipes",
        "@lume/foundation/types",
        "@ark-ui/react",
        "@ark-ui/react/dialog",
        "react"
      ]
    },
    {
      "name": "All primitives (barrel)",
      "path": "src/index.ts",
      "limit": "60 kB",
      "ignore": [
        "@lume/foundation",
        "@lume/foundation/css",
        "@lume/foundation/jsx",
        "@lume/foundation/recipes",
        "@lume/foundation/types",
        "@ark-ui/react",
        "react"
      ]
    }
  ]
}
