{
	"name": "@lume/system",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "panda codegen && panda cssgen --outfile styled-system/styles.css && storybook dev -p 6006 --no-open",
		"build": "panda codegen && panda cssgen --outfile styled-system/styles.css && storybook build",
		"codegen": "panda codegen && panda cssgen --outfile styled-system/styles.css",
		"check-types": "tsc --noEmit",
		"chromatic": "chromatic --exit-zero-on-changes"
	},
	"dependencies": {
		"@iconify-json/hugeicons": "catalog:icons",
		"@iconify/react": "catalog:icons",
		"@lume/blocks": "workspace:",
		"@lume/foundation": "workspace:",
		"@lume/primitives": "workspace:",
		"react": "catalog:react",
		"react-dom": "catalog:react"
	},
	"devDependencies": {
		"@pandacss/dev": "catalog:ui",
		"@repo/tsconfig": "workspace:",
		"@storybook/addon-a11y": "catalog:storybook",
		"@storybook/addon-designs": "catalog:storybook",
		"@storybook/addon-docs": "catalog:storybook",
		"@storybook/addon-themes": "catalog:storybook",
		"@storybook/react-vite": "catalog:storybook",
		"chromatic": "catalog:storybook",
		"@types/bun": "catalog:",
		"@types/react": "catalog:react",
		"@types/react-dom": "catalog:react",
		"storybook": "catalog:storybook",
		"vite": "catalog:storybook"
	},
	"peerDependencies": {
		"typescript": "catalog:"
	}
}
