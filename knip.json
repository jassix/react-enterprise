{
	"$schema": "https://unpkg.com/knip@5/schema.json",
	"ignore": ["**/styled-system/**", "**/storybook-static/**"],
	"workspaces": {
		".": {
			"entry": ["turbo.json"]
		},
		"apps/platform": {
			"entry": ["src/router.tsx", "src/routes/**/*.{ts,tsx}", "vite.config.ts"]
		},
		"packages/std": {
			"entry": ["src/*.ts"]
		},
		"packages/ui/foundation": {
			"entry": ["panda.config.ts", "src/preset.ts", "scripts/**/*.mjs"]
		},
		"packages/ui/primitives": {
			"entry": ["src/index.ts", "src/**/*.stories.tsx"]
		},
		"packages/ui/blocks": {
			"entry": ["src/index.ts"]
		},
		"packages/ui/system": {
			"entry": [
				".storybook/**/*.{ts,tsx}",
				"panda.config.ts",
				"src/docs/**/*.mdx"
			]
		},
		"tooling/cli": {
			"entry": ["src/**/*.ts"]
		}
	}
}
