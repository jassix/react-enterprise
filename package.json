{
  "name": "react-enterprise",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "packages/ui/*",
      "packages/sdk/*",
      "tooling/*",
      "tooling/config/*"
    ],
    "catalog": {
      "@types/bun": "^1.3.6",
      "typescript": "5.9.2"
    },
    "catalogs": {
      "std": {
        "oxide.ts": "^1.1.0",
        "remeda": "^2.33.4",
        "ts-pattern": "^5.9.0",
        "valibot": "^1.2.0"
      },
      "react": {
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0"
      },
      "ui": {
        "@pandacss/dev": "^1.8.1",
        "@ark-ui/react": "^5.30.0",
        "@fontsource-variable/figtree": "^5.2.10"
      },
      "storybook": {
        "storybook": "^9.0.0",
        "@storybook/react-vite": "^9.0.0",
        "@storybook/addon-a11y": "^9.0.0",
        "@storybook/addon-themes": "^9.0.0",
        "@storybook/addon-docs": "^9.0.0",
        "@storybook/addon-designs": "^10.0.0",
        "chromatic": "^13.0.0",
        "vite": "^6.0.0"
      },
      "icons": {
        "@iconify/react": "^6.0.2",
        "@iconify-json/hugeicons": "^1.2.26"
      },
      "cli": {
        "@clack/prompts": "^0.11.0"
      }
    }
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "repo": "bun tooling/cli/src/index.ts",
    "doctor": "bun --filter @repo/cli doctor",
    "adapt": "bun --filter @repo/cli adapt",
    "lint": "turbo run lint",
    "format": "oxfmt --write .",
    "check-types": "turbo run check-types",
    "knip": "knip",
    "size": "size-limit"
  },
  "devDependencies": {
    "knip": "^5.40.0",
    "oxfmt": "^0.27.0",
    "oxlint": "^1.42.0",
    "size-limit": "^11.1.0",
    "turbo": "^2.5.6"
  },
  "engines": {
    "bun": ">=1.3.5"
  },
  "packageManager": "bun@1.3.5"
}
