{
  "extends": "@repo/tsconfig/react.tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@/app/*": ["./src/app/*"],
      "@/pages/*": ["./src/pages/*"],
      "@/shared/*": ["./src/shared/*"],
      "~/system/*": ["./styled-system/*"]
    }
  },
  "include": ["src/**/*", "styled-system/**/*"]
}
