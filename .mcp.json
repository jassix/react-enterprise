{
  "mcpServers": {
    "ark-ui": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@ark-ui/mcp"
      ],
      "env": {}
    },
    "panda": {
      "command": "npx",
      "args": [
        "panda",
        "mcp"
      ]
    },
    "paper": {
      "type": "http",
      "url": "http://127.0.0.1:29979/mcp"
    }
  }
}